<robot
  name="zyarm_x1_standard"
  xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- use_ros2_control=false: 只做模型显示或真机串口桥接 -->
  <!-- use_ros2_control=true:  展开 ros2_control 标签，供控制器链和 MoveIt 仿真链使用 -->
  <xacro:arg name="use_ros2_control" default="true" />
  <xacro:arg name="use_gazebo" default="false" />
  <xacro:arg name="use_sim_cameras" default="false" />
  <xacro:arg name="use_real_hardware_interface" default="false" />
  <xacro:arg name="real_hardware_port" default="/dev/ttyUSB0" />
  <xacro:arg name="real_hardware_baud_rate" default="230400" />
  <xacro:arg name="real_hardware_read_timeout_ms" default="20" />
  <xacro:arg name="real_hardware_write_timeout_ms" default="20" />
  <xacro:arg name="real_hardware_activation_status_timeout_ms" default="1000" />
  <xacro:arg name="real_hardware_status_stale_warn_ms" default="100" />
  <xacro:arg name="real_hardware_status_stale_error_ms" default="1000" />
  <xacro:arg name="real_hardware_stale_log_period_ms" default="2000" />
  <xacro:arg name="real_hardware_reset_rts_dtr" default="false" />
  <xacro:arg name="real_hardware_reset_rts_dtr_quiet_ms" default="0" />
  <xacro:arg name="real_hardware_arm_hw_offsets_deg" default="0 -180 90 0 0 0" />
  <xacro:arg name="real_hardware_arm_hw_signs" default="1 1 1 1 1 1" />
  <xacro:arg name="real_hardware_claw_travel_m" default="0.034" />
  <xacro:arg name="real_hardware_claw_command_max" default="100" />
  <xacro:arg
    name="gazebo_camera_config_file"
    default="" />
  <xacro:arg
    name="gazebo_controller_config_file"
    default="" />
  <xacro:property name="use_ros2_control" value="$(arg use_ros2_control)" />
  <xacro:property name="use_gazebo" value="$(arg use_gazebo)" />
  <xacro:property name="use_sim_cameras" value="$(arg use_sim_cameras)" />
  <xacro:property name="use_real_hardware_interface" value="$(arg use_real_hardware_interface)" />
  <xacro:property name="arm_effort_limit" value="60.0" />
  <xacro:property name="gripper_effort_limit" value="160.0" />
  <xacro:property name="arm_base_velocity_limit" value="3.0" />
