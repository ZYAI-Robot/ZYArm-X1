    type="prismatic">
    <origin
      xyz="0 0 -0.18675"
      rpy="1.5708 0 1.5708" />
    <parent
      link="link6" />
    <child
      link="claw2" />
    <axis
      xyz="1 0 0" />
    <xacro:unless value="${use_gazebo}">
      <mimic
        joint="joint6"
        multiplier="1.0"
        offset="0.0" />
    </xacro:unless>
    <limit
      lower="0"
      upper="0.034"
      effort="${gripper_effort_limit}"
      velocity="${gripper_velocity_limit}" />
  </joint>
  <link name="ee_link" />
  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link6" />
    <child link="ee_link" />
    <origin xyz="0 0 -0.18675" rpy="1.5708 0 0" />
  </joint>
  <xacro:if value="${use_sim_cameras}">
    <xacro:property
      name="gazebo_camera_frames"
      value="${xacro.load_yaml(gazebo_camera_config_file)['camera_frames']}" />
    <link name="${gazebo_camera_frames['fixed']['link_frame']}" />
    <joint name="camera_fixed_joint" type="fixed">
      <parent link="base_link" />
      <child link="${gazebo_camera_frames['fixed']['link_frame']}" />
      <origin xyz="0.05 -0.30 0.45" rpy="-1.1 0 0" />
    </joint>
    <link name="${gazebo_camera_frames['fixed']['optical_frame']}" />
    <joint name="camera_fixed_optical_joint" type="fixed">
      <parent link="${gazebo_camera_frames['fixed']['link_frame']}" />
      <child link="${gazebo_camera_frames['fixed']['optical_frame']}" />
      <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
    </joint>
    <link name="${gazebo_camera_frames['wrist']['link_frame']}" />
    <joint name="camera_wrist_joint" type="fixed">
      <parent link="ee_link" />
      <child link="${gazebo_camera_frames['wrist']['link_frame']}" />
      <origin xyz="0.04 0.0 0.02" rpy="-1.57 0 -1.57" />
    </joint>
    <link name="${gazebo_camera_frames['wrist']['optical_frame']}" />
    <joint name="camera_wrist_optical_joint" type="fixed">
      <parent link="${gazebo_camera_frames['wrist']['link_frame']}" />
      <child link="${gazebo_camera_frames['wrist']['optical_frame']}" />
      <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
    </joint>
  </xacro:if>
  <xacro:if value="${use_ros2_control}">
    <ros2_control name="ZyarmX1StandardSystem" type="system">
      <hardware>
        <xacro:if value="${use_real_hardware_interface}">
          <plugin>zyarm_hardware_interface/ZyArmSystemHardware</plugin>
          <param name="port">$(arg real_hardware_port)</param>
          <param name="baud_rate">$(arg real_hardware_baud_rate)</param>
          <param name="read_timeout_ms">$(arg real_hardware_read_timeout_ms)</param>
          <param name="write_timeout_ms">$(arg real_hardware_write_timeout_ms)</param>
          <param name="activation_status_timeout_ms">$(arg real_hardware_activation_status_timeout_ms)</param>
          <param name="status_stale_warn_ms">$(arg real_hardware_status_stale_warn_ms)</param>
          <param name="status_stale_error_ms">$(arg real_hardware_status_stale_error_ms)</param>
          <param name="stale_log_period_ms">$(arg real_hardware_stale_log_period_ms)</param>
          <param name="reset_rts_dtr">$(arg real_hardware_reset_rts_dtr)</param>
          <param name="reset_rts_dtr_quiet_ms">$(arg real_hardware_reset_rts_dtr_quiet_ms)</param>
          <param name="arm_hw_offsets_deg">$(arg real_hardware_arm_hw_offsets_deg)</param>
          <param name="arm_hw_signs">$(arg real_hardware_arm_hw_signs)</param>
          <param name="claw_travel_m">$(arg real_hardware_claw_travel_m)</param>
          <param name="claw_command_max">$(arg real_hardware_claw_command_max)</param>
        </xacro:if>
        <xacro:unless value="${use_real_hardware_interface}">
          <xacro:if value="${use_gazebo}">
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
          </xacro:if>
          <xacro:unless value="${use_gazebo}">
            <plugin>mock_components/GenericSystem</plugin>
          </xacro:unless>
        </xacro:unless>
      </hardware>
      <joint name="joint0">
        <command_interface name="position" />
        <state_interface name="position" />
        <xacro:unless value="${use_real_hardware_interface}">
          <state_interface name="velocity" />
        </xacro:unless>
      </joint>
      <joint name="joint1">
        <command_interface name="position" />
        <state_interface name="position" />
        <xacro:unless value="${use_real_hardware_interface}">
          <state_interface name="velocity" />
        </xacro:unless>
      </joint>
      <joint name="joint2">
        <command_interface name="position" />
        <state_interface name="position" />
        <xacro:unless value="${use_real_hardware_interface}">
          <state_interface name="velocity" />
        </xacro:unless>
      </joint>
      <joint name="joint3">
        <command_interface name="position" />
        <state_interface name="position" />
        <xacro:unless value="${use_real_hardware_interface}">
          <state_interface name="velocity" />
        </xacro:unless>
      </joint>
      <joint name="joint4">
        <command_interface name="position" />
        <state_interface name="position" />
        <xacro:unless value="${use_real_hardware_interface}">
          <state_interface name="velocity" />
        </xacro:unless>
      </joint>
      <joint name="joint5">
        <command_interface name="position" />
        <state_interface name="position" />
        <xacro:unless value="${use_real_hardware_interface}">
          <state_interface name="velocity" />
        </xacro:unless>
      </joint>
      <joint name="joint6">
        <command_interface name="position" />
        <state_interface name="position" />
        <xacro:unless value="${use_real_hardware_interface}">
          <state_interface name="velocity" />
        </xacro:unless>
      </joint>
      <xacro:if value="${use_gazebo and not use_real_hardware_interface}">
        <joint name="joint7">
          <command_interface name="position" />
          <state_interface name="position" />
          <state_interface name="velocity" />
        </joint>
      </xacro:if>
    </ros2_control>
  </xacro:if>
  <xacro:if value="${use_gazebo}">
    <xacro:if value="${use_ros2_control}">
      <gazebo>
        <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
          <controller_manager_name>zyarm_x1_standard_controller_manager</controller_manager_name>
          <xacro:if value="${gazebo_controller_config_file != ''}">
            <parameters>${gazebo_controller_config_file}</parameters>
          </xacro:if>
          <xacro:unless value="${gazebo_controller_config_file != ''}">
            <parameters>$(find zyarm_control)/config/zyarm_x1_standard_gazebo_controllers.yaml</parameters>
          </xacro:unless>
        </plugin>
      </gazebo>
    </xacro:if>
  </xacro:if>
  <xacro:if value="${use_gazebo}">
    <xacro:if value="${use_sim_cameras}">
      <gazebo reference="${gazebo_camera_frames['fixed']['link_frame']}">
        <sensor name="fixed_rgb" type="camera">
          <always_on>true</always_on>
          <update_rate>30</update_rate>
          <topic>${gazebo_camera_frames['fixed']['image_topic']}</topic>
          <camera>
            <horizontal_fov>1.05</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.01</near>
              <far>5.0</far>
            </clip>
          </camera>
        </sensor>
      </gazebo>
      <gazebo reference="${gazebo_camera_frames['wrist']['link_frame']}">
        <sensor name="wrist_rgb" type="camera">
          <always_on>true</always_on>
          <update_rate>30</update_rate>
          <topic>${gazebo_camera_frames['wrist']['image_topic']}</topic>
          <camera>
            <horizontal_fov>1.10</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.01</near>
              <far>3.0</far>
            </clip>
          </camera>
        </sensor>
      </gazebo>
    </xacro:if>
  </xacro:if>
</robot>
